za"},{"lang":"Chinese \u200e(zh)\u200e","code":"zh"},{"lang":"Zulu \u200e(zu)\u200e","code":"zu"}]},"help":{"addsource":"&lt;a class=\"btn btn-link p-0\" role=\"button\"\n    data-container=\"body\" data-toggle=\"popover\"\n    data-placement=\"right\" data-content=\"&amp;lt;div class=&amp;quot;no-overflow&amp;quot;&amp;gt;&amp;lt;p&amp;gt;It is recommended that an alternative media source is provided, since desktop and mobile browsers vary in which file formats they support.&amp;lt;\/p&amp;gt;\n&amp;lt;\/div&amp;gt; \"\n    data-html=\"true\" tabindex=\"0\" data-trigger=\"focus\"&gt;\n  &lt;i class=\"icon fa fa-question-circle text-info fa-fw \"  title=\"Help with Add alternative source\" aria-label=\"Help with Add alternative source\"&gt;&lt;\/i&gt;\n&lt;\/a&gt;","tracks":"&lt;a class=\"btn btn-link p-0\" role=\"button\"\n    data-container=\"body\" data-toggle=\"popover\"\n    data-placement=\"right\" data-content=\"&amp;lt;div class=&amp;quot;no-overflow&amp;quot;&amp;gt;&amp;lt;p&amp;gt;Subtitles, captions, chapters and descriptions can be added via a WebVTT (Web Video Text Tracks) format file. Track labels will be shown in the selection drop-down menu. For each type of track, any track set as default will be pre-selected at the start of the video.&amp;lt;\/p&amp;gt;\n&amp;lt;\/div&amp;gt; \"\n    data-html=\"true\" tabindex=\"0\" data-trigger=\"focus\"&gt;\n  &lt;i class=\"icon fa fa-question-circle text-info fa-fw \"  title=\"Help with Subtitles and captions\" aria-label=\"Help with Subtitles and captions\"&gt;&lt;\/i&gt;\n&lt;\/a&gt;","subtitles":"&lt;a class=\"btn btn-link p-0\" role=\"button\"\n    data-container=\"body\" data-toggle=\"popover\"\n    data-placement=\"right\" data-content=\"&amp;lt;div class=&amp;quot;no-overflow&amp;quot;&amp;gt;&amp;lt;p&amp;gt;Subtitles may be used to provide a transcription or translation of the dialogue.&amp;lt;\/p&amp;gt;\n&amp;lt;\/div&amp;gt; \"\n    data-html=\"true\" tabindex=\"0\" data-trigger=\"focus\"&gt;\n  &lt;i class=\"icon fa fa-question-circle text-info fa-fw \"  title=\"Help with Subtitles\" aria-label=\"Help with Subtitles\"&gt;&lt;\/i&gt;\n&lt;\/a&gt;","captions":"&lt;a class=\"btn btn-link p-0\" role=\"button\"\n    data-container=\"body\" data-toggle=\"popover\"\n    data-placement=\"right\" data-content=\"&amp;lt;div class=&amp;quot;no-overflow&amp;quot;&amp;gt;&amp;lt;p&amp;gt;Captions may be used to describe everything happening in the track, including non-verbal sounds such as a phone ringing.&amp;lt;\/p&amp;gt;\n&amp;lt;\/div&amp;gt; \"\n    data-html=\"true\" tabindex=\"0\" data-trigger=\"focus\"&gt;\n  &lt;i class=\"icon fa fa-question-circle text-info fa-fw \"  title=\"Help with Captions\" aria-label=\"Help with Captions\"&gt;&lt;\/i&gt;\n&lt;\/a&gt;","descriptions":"&lt;a class=\"btn btn-link p-0\" role=\"button\"\n    data-container=\"body\" data-toggle=\"popover\"\n    data-placement=\"right\" data-content=\"&amp;lt;div class=&amp;quot;no-overflow&amp;quot;&amp;gt;&amp;lt;p&amp;gt;Audio descriptions may be used to provide a narration which explains visual details not apparent from the audio alone.&amp;lt;\/p&amp;gt;\n&amp;lt;\/div&amp;gt; \"\n    data-html=\"true\" tabindex=\"0\" data-trigger=\"focus\"&gt;\n  &lt;i class=\"icon fa fa-question-circle text-info fa-fw \"  title=\"Help with Descriptions\" aria-label=\"Help with Descriptions\"&gt;&lt;\/i&gt;\n&lt;\/a&gt;","chapters":"&lt;a class=\"btn btn-link p-0\" role=\"button\"\n    data-container=\"body\" data-toggle=\"popover\"\n    data-placement=\"right\" data-content=\"&amp;lt;div class=&amp;quot;no-overflow&amp;quot;&amp;gt;&amp;lt;p&amp;gt;Chapter titles may be provided for use in navigating the media resource.&amp;lt;\/p&amp;gt;\n&amp;lt;\/div&amp;gt; \"\n    data-html=\"true\" tabindex=\"0\" data-trigger=\"focus\"&gt;\n  &lt;i class=\"icon fa fa-question-circle text-info fa-fw \"  title=\"Help with Chapters\" aria-label=\"Help with Chapters\"&gt;&lt;\/i&gt;\n&lt;\/a&gt;","metadata":"&lt;a class=\"btn btn-link p-0\" role=\"button\"\n    data-container=\"body\" data-toggle=\"popover\"\n    data-placement=\"right\" data-content=\"&amp;lt;div class=&amp;quot;no-overflow&amp;quot;&amp;gt;&amp;lt;p&amp;gt;Metadata tracks, for use from a script, may be used only if the player supports metadata.&amp;lt;\/p&amp;gt;\n&amp;lt;\/div&amp;gt; \"\n    data-html=\"true\" tabindex=\"0\" data-trigger=\"focus\"&gt;\n  &lt;i class=\"icon fa fa-question-circle text-info fa-fw \"  title=\"Help with Metadata\" aria-label=\"Help with Metadata\"&gt;&lt;\/i&gt;\n&lt;\/a&gt;"}},{"name":"recordrtc","params":[],"contextid":186000,"sesskey":"cu2MwPFOlb","allowedtypes":"both","audiobitrate":"128000","videobitrate":"2500000","timelimit":"120","audiortcicon":"i\/audiortc","videortcicon":"i\/videortc","maxrecsize":2097152},{"name":"managefiles","params":[],"disabled":false,"area":{"context":186000,"areamaxbytes":-1,"maxbytes":2097152,"subdirs":0,"return_types":3,"removeorphaneddrafts":false},"usercontext":186003}]},{"group":"style2","plugins":[{"name":"underline","params":[]},{"name":"strike","params":[]},{"name":"subscript","params":[]},{"name":"superscript","params":[]}]},{"group":"align","plugins":[{"name":"align","params":[]}]},{"group":"indent","plugins":[{"name":"indent","params":[]}]},{"group":"insert","plugins":[{"name":"equation","params":[],"texfilteractive":true,"contextid":186000,"library":{"group1":{"groupname":"librarygroup1","elements":"\n\\cdot\n\\times\n\\ast\n\\div\n\\diamond\n\\pm\n\\mp\n\\oplus\n\\ominus\n\\otimes\n\\oslash\n\\odot\n\\circ\n\\bullet\n\\asymp\n\\equiv\n\\subseteq\n\\supseteq\n\\leq\n\\geq\n\\preceq\n\\succeq\n\\sim\n\\simeq\n\\approx\n\\subset\n\\supset\n\\ll\n\\gg\n\\prec\n\\succ\n\\infty\n\\in\n\\ni\n\\forall\n\\exists\n\\neq\n"},"group2":{"groupname":"librarygroup2","elements":"\n\\leftarrow\n\\rightarrow\n\\uparrow\n\\downarrow\n\\leftrightarrow\n\\nearrow\n\\searrow\n\\swarrow\n\\nwarrow\n\\Leftarrow\n\\Rightarrow\n\\Uparrow\n\\Downarrow\n\\Leftri